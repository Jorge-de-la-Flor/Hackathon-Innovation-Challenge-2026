{
  "name": "FocusFlow AI",
  "version": "1.0",
  "manifest_version": 3,
  "description": "Asistente de Resiliencia Cognitiva con IA",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}